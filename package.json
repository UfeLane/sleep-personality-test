{
  "name": "sleep-personality-test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "眠格自测｜解锁专属睡眠人格报告",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "vite",
    "server": "npx tsx server/index.ts",
    "client": "vite",
    "dev:all": "npx concurrently -n server,client -c blue,green \"npx tsx server/index.ts\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production npx tsx server/index.ts",
    "deploy:build": "cd client && npx vite build"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "chart.js": "^4.4.7",
    "express": "^4.18.2",
    "framer-motion": "^11.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tsx": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
